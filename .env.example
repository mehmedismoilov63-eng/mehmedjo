# GHOST Assistant Environment Variables
# Copy this file to .env and fill in your values

# PicoVoice API Key (for wake word detection)
# Get from: https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# Telegram Bot Token (optional)
# Create bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Owner ID (auto-filled on first /start)
TELEGRAM_OWNER_ID=your_telegram_id_here

# Claude Bridge Mini App URL
# Local: http://localhost:8000
# Production: https://your-app.railway.app
GHOST_MINIAPP_URL=http://localhost:8000

# Debug mode (optional)
GHOST_DEBUG=false
