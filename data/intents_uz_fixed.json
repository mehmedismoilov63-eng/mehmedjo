{
  "greeting.hello": {
    "patterns": [
      "salom",
      "assalomu alaykum",
      "salom alekum",
      "hello",
      "hayr",
      "qalaysiz",
      "yaxshimisiz"
    ],
    "responses": [
      "Salom! Nima yordam bera olaman?",
      "Assalomu alaykum! Qanday yordam kerak?",
      "Hello! How can I help you?"
    ]
  },
  "greeting.how_are_you": {
    "patterns": [
      "qalaysiz",
      "yaxshimisiz",
      "how are you",
      "qandaysan"
    ],
    "responses": [
      "Yaxshi, rahmat! Sizchi?",
      "I'm fine, thank you! And you?",
      "Yaxshi, ishlayapman. Nima qilish kerak?"
    ]
  },
  "system.volume_up": {
    "patterns": [
      "ovozni oshir",
      "ovoz baland qil", 
      "ovozni ko'tar",
      "volume up",
      "balandroq qil",
      "ovozni [\\d]+ ga oshir",
      "ovoz [\\d]+ ga oshir"
    ],
    "parameters": {
      "amount": {"type": "number", "default": 10}
    }
  },
  "system.volume_down": {
    "patterns": [
      "ovozni kamaytir",
      "ovozni pastga tushir",
      "ovozni pasaytir", 
      "volume down",
      "ovozni [\\d]+ ga kamaytir",
      "ovoz [\\d]+ ga kamaytir"
    ],
    "parameters": {
      "amount": {"type": "number", "default": 10}
    }
  },
  "system.volume_mute": {
    "patterns": [
      "ovozni o'chir",
      "ovozni shu",
      "volume mute",
      "ovozni o'chirib qoy",
      "ovozni o'chir"
    ]
  },
